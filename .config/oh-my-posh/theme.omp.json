{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#ebdbb2",
          "style": "plain",
          "template": "<#7c6f64>┌</>{{ if ne .Env.POSH_SESSION_DEFAULT_USER .UserName }}<#f9c74f>{{ .UserName }}</><#ebdbb2>@</></>{{ end }}<#8ecbff>{{ .HostName }}</><#7c6f64> | </>",
          "type": "session"
        },
        {
          "foreground": "#ff7b72",
          "style": "plain",
          "template": "󱐋<#7c6f64> | </>",
          "type": "root"
        },
        {
          "foreground": "#ebdbb2",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#b8d76a",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#f9c74f{{ end }}",
            "{{ if gt .Ahead 0 }}#8ecbff{{ end }}",
            "{{ if gt .Behind 0 }}#ff7b72{{ end }}"
          ],
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#7c6f64>| </>{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}<#ff7b72> {{ .Working.String }}</>{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }}{{ end }}{{ if .Staging.Changed }}<#b8d76a> {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} [{{ .StashCount }}]{{ end }} ",
          "type": "git"
        },
        {
          "foreground": "#b8d76a",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": "<#7c6f64>| </>{{ .CurrentDate | date .Format }} ",
          "type": "time"
        },
        {
          "foreground": "#f9c74f",
          "options": {
            "style": "roundrock",
            "threshold": 500
          },
          "style": "plain",
          "template": "<#7c6f64>| </>{{ .FormattedMs }} </>",
          "type": "executiontime"
        },
        {
          "foreground": "#b8d76a",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ff7b72{{ end }}"
          ],
          "options": {
            "always_enabled": false
          },
          "style": "plain",
          "template": "<#7c6f64>| </>{{ if gt .Code 0 }} {{ .Code }}{{ end }} ",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#ebdbb2",
          "style": "plain",
          "template": "<#7c6f64>└</><#8ecbff>$</>",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}root :: {{end}}{{.Shell}} :: {{.Folder}}",
  "final_space": true,
  "version": 4
}
