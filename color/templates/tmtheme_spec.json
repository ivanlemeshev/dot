{
  "name": "Custom",
  "global_settings": [
    { "key": "background", "color": "background" },
    { "key": "foreground", "color": "foreground" },
    { "key": "caret", "color": "foreground" },
    { "key": "lineHighlight", "color": "black" },
    { "key": "selection", "color": "white" },
    { "key": "selectionBorder", "color": "brightBlack" },
    { "key": "invisibles", "color": "black" },
    { "key": "guide", "color": "brightBlack" },
    { "key": "activeGuide", "color": "brightBlack" },
    { "key": "gutter", "color": "background" },
    { "key": "gutterForeground", "color": "brightBlack" },
    { "key": "findHighlight", "color": "yellow" },
    { "key": "findHighlightForeground", "color": "background" },
    { "key": "bracketsForeground", "color": "foreground" },
    { "key": "bracketContentsForeground", "color": "foreground" }
  ],
  "entries": [
    {
      "name": "Comment",
      "scope": "comment, punctuation.definition.comment",
      "color": "brightBlack",
      "fontStyle": "italic"
    },
    { "name": "String", "scope": "string", "color": "green" },
    {
      "name": "Escape Character",
      "scope": "constant.character.escape",
      "color": "cyan"
    },
    { "name": "Number", "scope": "constant.numeric", "color": "brightMagenta" },
    {
      "name": "Built-in Constant",
      "scope": "constant.language",
      "color": "brightCyan"
    },
    { "name": "Constant", "scope": "constant.other", "color": "brightCyan" },
    {
      "name": "Keyword",
      "scope": "keyword, keyword.control",
      "color": "red",
      "fontStyle": "italic"
    },
    { "name": "Operator", "scope": "keyword.operator", "color": "yellow" },
    { "name": "Storage Type", "scope": "storage.type", "color": "yellow" },
    {
      "name": "Storage Modifier",
      "scope": "storage.modifier",
      "color": "yellow"
    },
    {
      "name": "Function Name",
      "scope": "entity.name.function, meta.function-call",
      "color": "brightGreen"
    },
    {
      "name": "Class Name",
      "scope": "entity.name.class, entity.name.type, entity.name.namespace, entity.name.struct",
      "color": "yellow"
    },
    {
      "name": "Inherited Class",
      "scope": "entity.other.inherited-class",
      "color": "yellow"
    },
    {
      "name": "Function Parameter",
      "scope": "variable.parameter",
      "color": "foreground"
    },
    {
      "name": "Variable",
      "scope": "variable, variable.other",
      "color": "blue"
    },
    {
      "name": "Language Variable",
      "scope": "variable.language",
      "color": "blue",
      "fontStyle": "italic"
    },
    {
      "name": "Support Function",
      "scope": "support.function",
      "color": "brightGreen"
    },
    {
      "name": "Support Type",
      "scope": "support.type, support.class",
      "color": "yellow"
    },
    {
      "name": "Support Constant",
      "scope": "support.constant",
      "color": "brightCyan"
    },
    {
      "name": "Preprocessor",
      "scope": "meta.preprocessor, keyword.control.import, keyword.control.directive",
      "color": "magenta",
      "fontStyle": "italic"
    },
    {
      "name": "Include",
      "scope": "keyword.control.include, keyword.control.from",
      "color": "magenta",
      "fontStyle": "italic"
    },
    {
      "name": "Type Annotation",
      "scope": "meta.type, storage.type.annotation",
      "color": "yellow"
    },
    {
      "name": "Decorator",
      "scope": "meta.decorator, punctuation.definition.annotation",
      "color": "magenta",
      "fontStyle": "italic"
    },
    { "name": "Tag Name", "scope": "entity.name.tag", "color": "yellow" },
    {
      "name": "Tag Attribute",
      "scope": "entity.other.attribute-name",
      "color": "green"
    },
    {
      "name": "Punctuation",
      "scope": "punctuation.separator, punctuation.terminator, punctuation.section",
      "color": "foreground"
    },
    {
      "name": "Tag Punctuation",
      "scope": "punctuation.definition.tag",
      "color": "green"
    },
    {
      "name": "String Punctuation",
      "scope": "punctuation.definition.string",
      "color": "foreground"
    },
    { "name": "Regular Expression", "scope": "string.regexp", "color": "cyan" },
    {
      "name": "CSS Property",
      "scope": "support.type.property-name.css",
      "color": "green"
    },
    {
      "name": "CSS Value",
      "scope": "support.constant.property-value.css, meta.property-value.css",
      "color": "yellow"
    },
    {
      "name": "JSON Key",
      "scope": "support.type.property-name.json, meta.structure.dictionary.key.json string",
      "color": "blue"
    },
    { "name": "YAML Key", "scope": "entity.name.tag.yaml", "color": "blue" },
    {
      "name": "Diff Inserted",
      "scope": "markup.inserted, meta.diff.header.to-file",
      "color": "green"
    },
    {
      "name": "Diff Deleted",
      "scope": "markup.deleted, meta.diff.header.from-file",
      "color": "red"
    },
    { "name": "Diff Changed", "scope": "markup.changed", "color": "green" },
    {
      "name": "Diff Range",
      "scope": "meta.diff.range, meta.diff.index",
      "color": "magenta"
    },
    {
      "name": "Markup Heading",
      "scope": "markup.heading, punctuation.definition.heading",
      "color": "brightYellow"
    },
    {
      "name": "Markup Bold",
      "scope": "markup.bold",
      "color": "yellow",
      "fontStyle": "bold"
    },
    {
      "name": "Markup Italic",
      "scope": "markup.italic",
      "color": "magenta",
      "fontStyle": "italic"
    },
    {
      "name": "Markup Link URL",
      "scope": "markup.underline.link, string.other.link",
      "color": "blue"
    },
    {
      "name": "Markup Link Text",
      "scope": "string.other.link.title, string.other.link.description",
      "color": "magenta"
    },
    {
      "name": "Markup Inline Code",
      "scope": "markup.inline.raw, markup.raw",
      "color": "green"
    },
    {
      "name": "Markup List",
      "scope": "markup.list punctuation.definition.list_item",
      "color": "red"
    },
    {
      "name": "Markup Quote",
      "scope": "markup.quote",
      "color": "brightBlack",
      "fontStyle": "italic"
    },
    { "name": "Invalid", "scope": "invalid", "color": "red" },
    {
      "name": "Invalid Deprecated",
      "scope": "invalid.deprecated",
      "color": "magenta"
    }
  ]
}
