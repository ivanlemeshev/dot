{
	"name": "Custom Color Theme",
	"global_settings": [
		{ "key": "background", "color": "ui.bg" },
		{ "key": "foreground", "color": "ui.fg" },
		{ "key": "caret", "color": "ui.cursor" },
		{ "key": "lineHighlight", "color": "ui.cursor_line" },
		{ "key": "selection", "color": "ui.selection_bg" },
		{ "key": "selectionBorder", "color": "ui.float_border_fg" },
		{ "key": "invisibles", "color": "ui.whitespace" },
		{ "key": "guide", "color": "ui.split_fg" },
		{ "key": "activeGuide", "color": "ui.cursor_line_nr" },
		{ "key": "gutter", "color": "ui.bg" },
		{ "key": "gutterForeground", "color": "ui.line_nr" },
		{ "key": "findHighlight", "color": "ui.search_bg" },
		{ "key": "findHighlightForeground", "color": "ui.search_fg" },
		{ "key": "bracketsForeground", "color": "syntax.delimiter" },
		{ "key": "bracketContentsForeground", "color": "ui.fg" }
	],
	"entries": [
		{
			"name": "Comment",
			"scope": "comment, punctuation.definition.comment",
			"color": "syntax.comment",
			"fontStyle": "italic"
		},
		{ "name": "String", "scope": "string", "color": "syntax.string" },
		{
			"name": "Escape Character",
			"scope": "constant.character.escape",
			"color": "syntax.string_escape"
		},
		{ "name": "Number", "scope": "constant.numeric", "color": "syntax.number" },
		{
			"name": "Built-in Constant",
			"scope": "constant.language",
			"color": "syntax.constant_builtin"
		},
		{
			"name": "Constant",
			"scope": "constant.other",
			"color": "syntax.constant"
		},
		{
			"name": "Keyword",
			"scope": "keyword, keyword.control",
			"color": "syntax.keyword",
			"fontStyle": "italic"
		},
		{
			"name": "Operator",
			"scope": "keyword.operator",
			"color": "syntax.operator"
		},
		{ "name": "Storage Type", "scope": "storage.type", "color": "syntax.storageclass" },
		{
			"name": "Storage Modifier",
			"scope": "storage.modifier",
			"color": "syntax.keyword_modifier",
			"fontStyle": "italic"
		},
		{
			"name": "Function Name",
			"scope": "entity.name.function, meta.function-call",
			"color": "syntax.function"
		},
		{
			"name": "Class Name",
			"scope": "entity.name.class, entity.name.type, entity.name.namespace, entity.name.struct",
			"color": "syntax.type"
		},
		{
			"name": "Inherited Class",
			"scope": "entity.other.inherited-class",
			"color": "syntax.type"
		},
		{
			"name": "Function Parameter",
			"scope": "variable.parameter",
			"color": "syntax.parameter"
		},
		{
			"name": "Variable",
			"scope": "variable, variable.other",
			"color": "syntax.variable"
		},
		{
			"name": "Language Variable",
			"scope": "variable.language",
			"color": "syntax.variable_builtin",
			"fontStyle": "italic"
		},
		{
			"name": "Support Function",
			"scope": "support.function",
			"color": "syntax.function_builtin"
		},
		{
			"name": "Support Type",
			"scope": "support.type, support.class",
			"color": "syntax.type_builtin"
		},
		{
			"name": "Support Constant",
			"scope": "support.constant",
			"color": "syntax.constant_builtin"
		},
		{
			"name": "Preprocessor",
			"scope": "meta.preprocessor, keyword.control.import, keyword.control.directive",
			"color": "syntax.keyword_directive",
			"fontStyle": "italic"
		},
		{
			"name": "Include",
			"scope": "keyword.control.include, keyword.control.from",
			"color": "syntax.keyword_import",
			"fontStyle": "italic"
		},
		{
			"name": "Type Annotation",
			"scope": "meta.type, storage.type.annotation",
			"color": "syntax.storageclass"
		},
		{
			"name": "Decorator",
			"scope": "meta.decorator, punctuation.definition.annotation",
			"color": "syntax.attribute",
			"fontStyle": "italic"
		},
		{
			"name": "Tag Name",
			"scope": "entity.name.tag",
			"color": "syntax.tag"
		},
		{
			"name": "Tag Attribute",
			"scope": "entity.other.attribute-name",
			"color": "syntax.tag_attribute"
		},
		{
			"name": "Punctuation",
			"scope": "punctuation.separator, punctuation.terminator, punctuation.section",
			"color": "syntax.punctuation_delimiter"
		},
		{
			"name": "Tag Punctuation",
			"scope": "punctuation.definition.tag",
			"color": "syntax.punctuation_delimiter"
		},
		{
			"name": "String Punctuation",
			"scope": "punctuation.definition.string",
			"color": "syntax.punctuation_delimiter"
		},
		{
			"name": "Regular Expression",
			"scope": "string.regexp",
			"color": "syntax.string_regexp"
		},
		{
			"name": "CSS Property",
			"scope": "support.type.property-name.css",
			"color": "syntax.property"
		},
		{
			"name": "CSS Value",
			"scope": "support.constant.property-value.css, meta.property-value.css",
			"color": "syntax.constant"
		},
		{
			"name": "JSON Key",
			"scope": "support.type.property-name.json, meta.structure.dictionary.key.json string",
			"color": "syntax.property"
		},
		{
			"name": "YAML Key",
			"scope": "entity.name.tag.yaml",
			"color": "syntax.property"
		},
		{
			"name": "Diff Inserted",
			"scope": "markup.inserted, meta.diff.header.to-file",
			"color": "git.add"
		},
		{
			"name": "Diff Deleted",
			"scope": "markup.deleted, meta.diff.header.from-file",
			"color": "git.delete"
		},
		{
			"name": "Diff Changed",
			"scope": "markup.changed",
			"color": "git.change"
		},
		{
			"name": "Diff Range",
			"scope": "meta.diff.range, meta.diff.index",
			"color": "ui.selection_bg"
		},
		{
			"name": "Markup Heading",
			"scope": "markup.heading, punctuation.definition.heading",
			"color": "syntax.markup_heading"
		},
		{
			"name": "Markup Bold",
			"scope": "markup.bold",
			"fontStyle": "bold"
		},
		{
			"name": "Markup Italic",
			"scope": "markup.italic",
			"fontStyle": "italic"
		},
		{
			"name": "Markup Link URL",
			"scope": "markup.underline.link, string.other.link",
			"color": "syntax.markup_link_url",
			"fontStyle": "underline"
		},
		{
			"name": "Markup Link Text",
			"scope": "string.other.link.title, string.other.link.description",
			"color": "syntax.markup_link_label"
		},
		{
			"name": "Markup Inline Code",
			"scope": "markup.inline.raw, markup.raw",
			"color": "syntax.markup_raw"
		},
		{
			"name": "Markup List",
			"scope": "markup.list punctuation.definition.list_item",
			"color": "syntax.markup_list"
		},
		{
			"name": "Markup Quote",
			"scope": "markup.quote",
			"color": "syntax.markup_quote",
			"fontStyle": "italic"
		},
		{ "name": "Invalid", "scope": "invalid", "color": "syntax.error" },
		{
			"name": "Invalid Deprecated",
			"scope": "invalid.deprecated",
			"color": "syntax.comment_special"
		}
	]
}
