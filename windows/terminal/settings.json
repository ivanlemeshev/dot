{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-profiles-schema",
  "actions": [
    {
      "command": {
        "action": "copy",
        "singleLine": false
      },
      "id": "User.copy"
    },
    {
      "command": "find",
      "id": "User.find"
    },
    {
      "command": "paste",
      "id": "User.paste"
    },
    {
      "command": {
        "action": "splitPane",
        "split": "auto",
        "splitMode": "duplicate"
      },
      "id": "User.splitPane"
    }
  ],
  "copyFormatting": "none",
  "copyOnSelect": true,
  "defaultProfile": "{c993c0b6-0023-5562-a928-3ea11eb283ce}",
  "keybindings": [
    {
      "id": "User.copy",
      "keys": "ctrl+shift+c"
    },
    {
      "id": "User.paste",
      "keys": "ctrl+shift+v"
    },
    {
      "id": "User.find",
      "keys": "ctrl+shift+f"
    },
    {
      "id": "User.splitPane",
      "keys": "alt+shift+d"
    }
  ],
  "newTabMenu": [
    {
      "type": "remainingProfiles"
    }
  ],
  "profiles": {
    "defaults": {
      "colorScheme": "Custom Scheme",
      "cursorShape": "filledBox",
      "font": {
        "builtinGlyphs": true,
        "cellHeight": "1.4",
        "colorGlyphs": true,
        "face": "Hack Nerd Font Mono",
        "size": 12,
        "weight": "normal"
      },
      "intenseTextStyle": "bright",
      "opacity": 100,
      "useAcrylic": false
    },
    "list": [
      {
        "commandline": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
        "guid": "{c993c0b6-0023-5562-a928-3ea11eb283ce}",
        "hidden": false,
        "icon": "\u26a1",
        "name": "Windows PowerShell",
        "startingDirectory": "%USERPROFILE%"
      },
      {
        "commandline": "%SystemRoot%\\System32\\cmd.exe",
        "guid": "{0c63d969-ef2e-52d4-8736-68efbb78152d}",
        "hidden": false,
        "icon": "\ud83d\udc1a",
        "name": "Command Prompt",
        "startingDirectory": "%USERPROFILE%"
      },
      {
        "commandline": "wsl.exe -d Ubuntu --cd ~",
        "guid": "{e381fe40-9d15-58b7-99ea-5908cd6561e5}",
        "hidden": false,
        "icon": "\ud83d\udc27",
        "name": "Ubuntu"
      },
      {
        "commandline": "C:\\msys64\\usr\\bin\\env.exe MSYSTEM=UCRT64 CHERE_INVOKING=1 /usr/bin/bash -li",
        "guid": "{7a30f727-2f38-43d2-b84a-1138465a3859}",
        "hidden": false,
        "icon": "C:\\msys64\\msys2.ico",
        "name": "MSYS2",
        "startingDirectory": "C:\\msys64\\home\\%USERNAME%"
      }
    ]
  },
  "schemes": [
    {
      "background": "#0C0C0C",
      "black": "#202020",
      "blue": "#6179C2",
      "brightBlack": "#7A7A7A",
      "brightBlue": "#5582C2",
      "brightCyan": "#73BFBF",
      "brightGreen": "#66CC69",
      "brightPurple": "#BF86BF",
      "brightRed": "#D96857",
      "brightWhite": "#CDCDCD",
      "brightYellow": "#CC9B52",
      "cursorColor": "#F2E6CF",
      "cyan": "#33919C",
      "foreground": "#F2E6CF",
      "green": "#2E9969",
      "name": "Custom Scheme",
      "purple": "#AB78AB",
      "red": "#CC5D4B",
      "selectionBackground": "#7A7A7A",
      "white": "#A5A5A5",
      "yellow": "#B38D59"
    }
  ],
  "themes": [
    {
      "name": "Custom Scheme",
      "tab": {
        "background": "#0C0C0CFF",
        "iconStyle": "default",
        "showCloseButton": "always",
        "unfocusedBackground": null
      },
      "tabRow": {
        "background": "#0C0C0CFF",
        "unfocusedBackground": "#3D3D3DFF"
      },
      "window": {
        "applicationTheme": "dark",
        "experimental.rainbowFrame": false,
        "frame": null,
        "unfocusedFrame": null,
        "useMica": false
      }
    }
  ]
}
