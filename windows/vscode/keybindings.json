[
    // =============================
    // ======= LEADER BINDS ========
    // =============================
    {
        // Write current file and format document
        "key": "space w",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.files.save",
                "editor.action.formatDocument"
            ]
        },
        "when": "vim.mode == 'Normal' && editorTextFocus"
    },
    {
        // Close current file
        "key": "space q",
        "command": "workbench.action.closeActiveEditor",
        "when": "vim.mode == 'Normal' && editorTextFocus"
    },
    {
        // Close all other files except the current one
        "key": "space shift+q",
        "command": "workbench.action.closeOtherEditors",
        "when": "(vim.mode == 'Normal' || vim.mode == 'Visual') && (editorTextFocus || !inputFocus)"
    },
    {
        // Find file in workspace
        "key": "space f f",
        "command": "workbench.action.quickOpen",
        "when": "(editorTextFocus && vim.mode == 'Normal') || (workbenchState == 'workspace' && !inputFocus && !terminalFocus)"
    },
    {
        // Find text in files in workspace
        "key": "space f p",
        "command": "workbench.action.quickTextSearch",
        "when": "(editorTextFocus && vim.mode == 'Normal') || (workbenchState == 'workspace' && !inputFocus && !terminalFocus)"
    },
    {
        // Find symbol in current file
        "key": "space f s",
        "command": "workbench.action.gotoSymbol",
        "when": "vim.mode == 'Normal' && editorTextFocus"
    },
    {
        // Open Git view and focus on the source control panel
        "key": "space g g",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.view.scm",
                "workbench.scm.focus"
            ]
        },
        "when": "vim.mode == 'Normal' && (editorTextFocus || !inputFocus)"
    },
    {
        // Open Problems panel
        "key": "space d d",
        "command": "workbench.actions.view.problems",
        "when": "vim.mode == 'Normal' && (editorTextFocus || !inputFocus)"
    },
    {
        // Split horizontally
        "key": "space s",
        "command": "workbench.action.splitEditorRight",
        "when": "vim.mode == 'Normal' && editorTextFocus"
    },
    {
        // Split vertically
        "key": "space v",
        "command": "workbench.action.splitEditorDown",
        "when": "vim.mode == 'Normal' && editorTextFocus"
    },
    // ================================
    // ========= NAVIGATION ===========
    // ================================
    {
        // Move focus to the left editor group
        "key": "ctrl-h",
        "command": "workbench.action.navigateLeft"
    },
    {
        // Move focus to the right editor group
        "key": "ctrl-l",
        "command": "workbench.action.navigateRight"
    },
    {
        // Move focus to the upper editor group
        "key": "ctrl-k",
        "command": "workbench.action.navigateUp"
    },
    {
        // Move focus to the lower editor group
        "key": "ctrl-j",
        "command": "workbench.action.navigateDown"
    },
    {
        // Move focus down in lists (e.g., file explorer, search results)
        "key": "ctrl+n",
        "command": "list.focusDown",
        "when": "listFocus"
    },
    {
        // Move focus up in lists (e.g., file explorer, search results)
        "key": "ctrl+p",
        "command": "list.focusUp",
        "when": "listFocus"
    },
    {
        // Move focus down in quick open (e.g., file search, command palette)
        "key": "ctrl+n",
        "command": "workbench.action.quickOpenSelectNext",
        "when": "inQuickOpen"
    },
    {
        // Move focus up in quick open (e.g., file search, command palette)
        "key": "ctrl+p",
        "command": "workbench.action.quickOpenSelectPrevious",
        "when": "inQuickOpen"
    },
    // ========================
    // ======= BUFFERS ========
    // ========================
    {
        // Next buffer
        "key": "tab",
        "command": "workbench.action.nextEditorInGroup",
        "when": "(vim.mode == 'Normal' || vim.mode == 'Visual') && (editorTextFocus || !inputFocus)"
    },
    {
        // Previous buffer
        "key": "shift-tab",
        "command": "workbench.action.previousEditorInGroup",
        "when": "(vim.mode == 'Normal' || vim.mode == 'Visual') && (editorTextFocus || !inputFocus)"
    },
    // ==========================
    // ======= FILE TREE ========
    // ==========================
    {
        // Toggle file explorer and focus on it
        "key": "space e",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.toggleSidebarVisibility",
                "workbench.files.action.focusFilesExplorer"
            ]
        },
        "when": "vim.mode == 'Normal' && (editorTextFocus || !inputFocus) && !sideBarVisible"
    },
    {
        // Toggle file explorer and return focus to the active editor group
        "key": "space e",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.toggleSidebarVisibility",
                "workbench.action.focusActiveEditorGroup"
            ]
        },
        "when": "vim.mode == 'Normal' && (editorTextFocus || !inputFocus) && sideBarVisible"
    },
    {
        // Rename file or folder
        "key": "r",
        "command": "renameFile",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // Copy file or folder
        "key": "c",
        "command": "filesExplorer.copy",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // Paste file or folder
        "key": "p",
        "command": "filesExplorer.paste",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // Cut file or folder
        "key": "x",
        "command": "filesExplorer.cut",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // Delete file or folder
        "key": "d",
        "command": "deleteFile",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // Create new file
        "key": "a",
        "command": "explorer.newFile",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // Create new folder
        "key": "shift-a",
        "command": "explorer.newFolder",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // Open file in a split editor to the side
        "key": "s",
        "command": "explorer.openToSide",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
    },
    {
        // Open file in a split editor below
        "key": "v",
        "command": "runCommands",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus",
        "args": {
            "commands": [
                "workbench.action.splitEditorDown",
                "explorer.openAndPassFocus"
            ]
        }
    },
    {
        // Open file and focus on the editor
        "key": "enter",
        "command": "explorer.openAndPassFocus",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceIsFolder && !inputFocus"
    },
    {
        // Toggle expand/collapse folder
        "key": "enter",
        "command": "list.toggleExpand",
        "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && explorerResourceIsFolder && !inputFocus"
    },
    // =========================
    // ======= TERMINAL ========
    // =========================
    {
        // Close the active bottom panel (terminal, problems, output, etc.)
        "key": "ctrl+\\",
        "command": "workbench.action.closePanel",
        "when": "panelVisible"
    },
    {
        // Open terminal when no panel is visible
        "key": "ctrl+\\",
        "command": "workbench.action.terminal.toggleTerminal",
        "when": "!panelVisible"
    },
    // =======================
    // ======= EDITOR ========
    // =======================
    {
        // Move focus down in the suggest widget
        "key": "ctrl+n",
        "command": "selectNextSuggestion",
        "when": "suggestWidgetVisible && textInputFocus"
    },
    {
        // Move focus up in the suggest widget
        "key": "ctrl+p",
        "command": "selectPrevSuggestion",
        "when": "suggestWidgetVisible && textInputFocus"
    },
    {
        // Accept inline suggestion from GitHub Copilot
        "key": "ctrl+f",
        "command": "editor.action.inlineSuggest.commit",
        "when": "editorTextFocus && vim.mode == 'Insert' && inlineSuggestionVisible"
    },
    {
        // Trigger find in the current file
        "key": "ctrl+f",
        "command": "actions.find",
        "when": "editorTextFocus && vim.mode == 'Normal'"
    },
    {
        // Close markers navigation
        "key": "escape",
        "command": "closeMarkersNavigation",
        "when": "editorFocus && markersNavigationVisible"
    },
    // =============================
    // ======== LSP BINDS ==========
    // =============================
    {
        // Go to definition
        "key": "g d",
        "command": "editor.action.revealDefinition",
        "when": "vim.mode == 'Normal' && editorTextFocus"
    },
    {
        // Go to reference
        "key": "g r r",
        "command": "editor.action.goToReferences",
        "when": "vim.mode == 'Normal' && editorTextFocus"
    },
    {
        // Go to implementation
        "key": "g r i",
        "command": "editor.action.goToImplementation",
        "when": "vim.mode == 'Normal' && editorTextFocus"
    },
    {
        // Show hover
        "key": "shift-k", // vim classic
        "command": "editor.action.showHover",
        "when": "vim.mode == 'Normal' && editorTextFocus"
    }
]
