{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#f2e6cf",
          "style": "plain",
          "template": "<#7a7a7a>┌</>{{ if ne .Env.POSH_SESSION_DEFAULT_USER .UserName }}<#b38d59>{{ .UserName }}</><#f2e6cf>@</></>{{ end }}<#6179c2>{{ .HostName }}</><#7a7a7a> | </>",
          "type": "session"
        },
        {
          "foreground": "#cc5d4b",
          "style": "plain",
          "template": "󱐋<#7a7a7a> | </>",
          "type": "root"
        },
        {
          "foreground": "#f2e6cf",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#2e9969",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#b38d59{{ end }}",
            "{{ if gt .Ahead 0 }}#6179c2{{ end }}",
            "{{ if gt .Behind 0 }}#cc5d4b{{ end }}"
          ],
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#7a7a7a>| </>{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}<#cc5d4b> {{ .Working.String }}</>{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }}{{ end }}{{ if .Staging.Changed }}<#2e9969> {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} [{{ .StashCount }}]{{ end }} ",
          "type": "git"
        },
        {
          "foreground": "#2e9969",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": "<#7a7a7a>| </>{{ .CurrentDate | date .Format }} ",
          "type": "time"
        },
        {
          "foreground": "#b38d59",
          "options": {
            "style": "roundrock",
            "threshold": 500
          },
          "style": "plain",
          "template": "<#7a7a7a>| </>{{ .FormattedMs }} </>",
          "type": "executiontime"
        },
        {
          "foreground": "#2e9969",
          "foreground_templates": ["{{ if gt .Code 0 }}#cc5d4b{{ end }}"],
          "options": {
            "always_enabled": false
          },
          "style": "plain",
          "template": "<#7a7a7a>| </>{{ if gt .Code 0 }} {{ .Code }}{{ end }} ",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#f2e6cf",
          "style": "plain",
          "template": "<#7a7a7a>└</><#6179c2>$</>",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}root :: {{end}}{{.Shell}} :: {{.Folder}}",
  "final_space": true,
  "version": 4
}
