{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-profiles-schema",
  "actions": [
    {
      "command": {
        "action": "copy",
        "singleLine": false
      },
      "id": "User.copy"
    },
    {
      "command": "find",
      "id": "User.find"
    },
    {
      "command": "paste",
      "id": "User.paste"
    },
    {
      "command": {
        "action": "splitPane",
        "split": "auto",
        "splitMode": "duplicate"
      },
      "id": "User.splitPane"
    }
  ],
  "copyFormatting": "none",
  "copyOnSelect": true,
  "defaultProfile": "{c993c0b6-0023-5562-a928-3ea11eb283ce}",
  "keybindings": [
    {
      "id": "User.copy",
      "keys": "ctrl+shift+c"
    },
    {
      "id": "User.paste",
      "keys": "ctrl+shift+v"
    },
    {
      "id": "User.find",
      "keys": "ctrl+shift+f"
    },
    {
      "id": "User.splitPane",
      "keys": "alt+shift+d"
    }
  ],
  "newTabMenu": [
    {
      "type": "remainingProfiles"
    }
  ],
  "profiles": {
    "defaults": {
      "colorScheme": "Custom",
      "cursorShape": "filledBox",
      "font": {
        "builtinGlyphs": true,
        "cellHeight": "1.4",
        "colorGlyphs": true,
        "face": "Hack Nerd Font Mono",
        "size": 12,
        "weight": "normal"
      },
      "intenseTextStyle": "bright",
      "opacity": 100,
      "useAcrylic": false
    },
    "list": [
      {
        "commandline": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
        "guid": "{c993c0b6-0023-5562-a928-3ea11eb283ce}",
        "hidden": false,
        "icon": "⚡",
        "name": "Windows PowerShell",
        "startingDirectory": "%USERPROFILE%"
      },
      {
        "commandline": "%SystemRoot%\\System32\\cmd.exe",
        "guid": "{0c63d969-ef2e-52d4-8736-68efbb78152d}",
        "hidden": false,
        "icon": "🐚",
        "name": "Command Prompt",
        "startingDirectory": "%USERPROFILE%"
      },
      {
        "commandline": "wsl.exe -d Ubuntu --cd ~",
        "guid": "{e381fe40-9d15-58b7-99ea-5908cd6561e5}",
        "hidden": false,
        "icon": "🐧",
        "name": "Ubuntu"
      }
    ]
  },
  "schemes": [
    {
      "background": "#0B0F0C",
      "black": "#0B0F0C",
      "blue": "#1F8A50",
      "brightBlack": "#455E49",
      "brightBlue": "#1F8A50",
      "brightCyan": "#34C96F",
      "brightGreen": "#3BD267",
      "brightPurple": "#5ACB88",
      "brightRed": "#2FA854",
      "brightWhite": "#83B18A",
      "brightYellow": "#61E686",
      "cursorColor": "#B7F7C0",
      "cyan": "#34C96F",
      "foreground": "#B7F7C0",
      "green": "#3BD267",
      "name": "Custom",
      "purple": "#5ACB88",
      "red": "#2FA854",
      "selectionBackground": "#1C261E",
      "white": "#B7F7C0",
      "yellow": "#61E686"
    }
  ],
  "themes": [
    {
      "name": "Custom Dark",
      "tab": {
        "background": "#0B0F0CFF",
        "iconStyle": "default",
        "showCloseButton": "always",
        "unfocusedBackground": null
      },
      "tabRow": {
        "background": "#0B0F0CFF",
        "unfocusedBackground": "#0B0F0CFF"
      },
      "window": {
        "applicationTheme": "dark",
        "experimental.rainbowFrame": false,
        "frame": null,
        "unfocusedFrame": null,
        "useMica": false
      }
    }
  ]
}
