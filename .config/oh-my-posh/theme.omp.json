{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#d8d8d8",
          "style": "plain",
          "template": "<#585858>┌</>{{ if ne .Env.POSH_SESSION_DEFAULT_USER .UserName }}<#f7ca88>{{ .UserName }}</><#d8d8d8>@</></>{{ end }}<#7cafc2>{{ .HostName }}</><#585858> | </>",
          "type": "session"
        },
        {
          "foreground": "#ab4642",
          "style": "plain",
          "template": "󱐋<#585858> | </>",
          "type": "root"
        },
        {
          "foreground": "#d8d8d8",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#a1b56c",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#f7ca88{{ end }}",
            "{{ if gt .Ahead 0 }}#7cafc2{{ end }}",
            "{{ if gt .Behind 0 }}#ab4642{{ end }}"
          ],
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#585858>| </>{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}<#ab4642> {{ .Working.String }}</>{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }}{{ end }}{{ if .Staging.Changed }}<#a1b56c> {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} [{{ .StashCount }}]{{ end }} ",
          "type": "git"
        },
        {
          "foreground": "#a1b56c",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": "<#585858>| </>{{ .CurrentDate | date .Format }} ",
          "type": "time"
        },
        {
          "foreground": "#f7ca88",
          "options": {
            "style": "roundrock",
            "threshold": 500
          },
          "style": "plain",
          "template": "<#585858>| </>{{ .FormattedMs }} </>",
          "type": "executiontime"
        },
        {
          "foreground": "#a1b56c",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#ab4642{{ end }}"
          ],
          "options": {
            "always_enabled": false
          },
          "style": "plain",
          "template": "<#585858>| </>{{ if gt .Code 0 }} {{ .Code }}{{ end }} ",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#d8d8d8",
          "style": "plain",
          "template": "<#585858>└</><#7cafc2>$</>",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}root :: {{end}}{{.Shell}} :: {{.Folder}}",
  "final_space": true,
  "version": 4
}
