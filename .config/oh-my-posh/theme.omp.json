{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#a7c080",
          "options": {
            "alpine": "",
            "arch": "",
            "centos": "",
            "debian": "",
            "elementary": "",
            "fedora": "",
            "gentoo": "",
            "linux": "",
            "macos": "",
            "manjaro": "",
            "mint": "",
            "opensuse": "",
            "raspbian": "",
            "ubuntu": "",
            "windows": ""
          },
          "style": "plain",
          "template": " {{ .Icon }}<#475258> | </>",
          "type": "os"
        },
        {
          "foreground": "#d3c6aa",
          "style": "plain",
          "template": "{{ if ne .Env.POSH_SESSION_DEFAULT_USER .UserName }}<#7fbbb3>{{ .UserName }}</><#dbbc7f>󰁥</></>{{ end }}<#83c092>{{ .HostName }}</><#475258> | </>",
          "type": "session"
        },
        {
          "foreground": "#dbbc7f",
          "style": "plain",
          "template": "󱐋<#475258> | </>",
          "type": "root"
        },
        {
          "foreground": "#d3c6aa",
          "options": {
            "style": "full"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#dbbc7f",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#dbbc7f{{ end }}",
            "{{ if gt .Ahead 0 }}#83c092{{ end }}",
            "{{ if gt .Behind 0 }}#d699b6{{ end }}"
          ],
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#475258>| </>{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}<#e67e80> 󰤌 {{ .Working.String }}</>{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<#a7c080>  {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }}  {{ .StashCount }}{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#a7c080",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": "  {{ .CurrentDate | date .Format }} ",
          "type": "time"
        },
        {
          "foreground": "#dbbc7f",
          "options": {
            "style": "roundrock",
            "threshold": 500
          },
          "style": "plain",
          "template": "  {{ .FormattedMs }} </>",
          "type": "executiontime"
        },
        {
          "foreground": "#a7c080",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#e67e80{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "  {{ if gt .Code 0 }}{{ .Code }}{{ end }} ",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#d3c6aa",
          "style": "plain",
          "template": "$",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}root :: {{end}}{{.Shell}} :: {{.Folder}}",
  "final_space": true,
  "version": 4
}
