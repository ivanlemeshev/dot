{
  "$help": "https://aka.ms/terminal-documentation",
  "$schema": "https://aka.ms/terminal-profiles-schema",
  "actions": [
    {
      "command": {
        "action": "copy",
        "singleLine": false
      },
      "id": "User.copy"
    },
    {
      "command": "find",
      "id": "User.find"
    },
    {
      "command": "paste",
      "id": "User.paste"
    },
    {
      "command": {
        "action": "splitPane",
        "split": "auto",
        "splitMode": "duplicate"
      },
      "id": "User.splitPane"
    }
  ],
  "copyFormatting": "none",
  "copyOnSelect": true,
  "defaultProfile": "{c993c0b6-0023-5562-a928-3ea11eb283ce}",
  "keybindings": [
    {
      "id": "User.copy",
      "keys": "ctrl+shift+c"
    },
    {
      "id": "User.paste",
      "keys": "ctrl+shift+v"
    },
    {
      "id": "User.find",
      "keys": "ctrl+shift+f"
    },
    {
      "id": "User.splitPane",
      "keys": "alt+shift+d"
    }
  ],
  "newTabMenu": [
    {
      "type": "remainingProfiles"
    }
  ],
  "profiles": {
    "defaults": {
      "colorScheme": "Custom",
      "cursorShape": "filledBox",
      "font": {
        "builtinGlyphs": true,
        "cellHeight": "1.4",
        "colorGlyphs": true,
        "face": "Hack Nerd Font Mono",
        "size": 12,
        "weight": "normal"
      },
      "intenseTextStyle": "bright",
      "opacity": 100,
      "useAcrylic": false
    },
    "list": [
      {
        "commandline": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
        "guid": "{c993c0b6-0023-5562-a928-3ea11eb283ce}",
        "hidden": false,
        "icon": "⚡",
        "name": "Windows PowerShell",
        "startingDirectory": "%USERPROFILE%"
      },
      {
        "commandline": "%SystemRoot%\\System32\\cmd.exe",
        "guid": "{0c63d969-ef2e-52d4-8736-68efbb78152d}",
        "hidden": false,
        "icon": "🐚",
        "name": "Command Prompt",
        "startingDirectory": "%USERPROFILE%"
      },
      {
        "commandline": "wsl.exe -d Ubuntu --cd ~",
        "guid": "{e381fe40-9d15-58b7-99ea-5908cd6561e5}",
        "hidden": false,
        "icon": "🐧",
        "name": "Ubuntu"
      }
    ]
  },
  "schemes": [
    {
      "background": "#1E1816",
      "black": "#1C1816",
      "blue": "#7DA6B8",
      "brightBlack": "#7B756D",
      "brightBlue": "#7FB4CA",
      "brightCyan": "#7AA89F",
      "brightGreen": "#98BB6C",
      "brightPurple": "#938AA9",
      "brightRed": "#E46876",
      "brightWhite": "#DDDACC",
      "brightYellow": "#E6C384",
      "cursorColor": "#DCD7BA",
      "cyan": "#87A3A1",
      "foreground": "#D1D1C7",
      "green": "#8BA37C",
      "name": "Custom",
      "purple": "#A993A8",
      "red": "#C9655E",
      "selectionBackground": "#7B756D",
      "white": "#DCD7BA",
      "yellow": "#D1B37D"
    }
  ],
  "themes": [
    {
      "name": "Custom Dark",
      "tab": {
        "background": "#1E1816FF",
        "iconStyle": "default",
        "showCloseButton": "always",
        "unfocusedBackground": null
      },
      "tabRow": {
        "background": "#1E1816FF",
        "unfocusedBackground": "#1E1816FF"
      },
      "window": {
        "applicationTheme": "dark",
        "experimental.rainbowFrame": false,
        "frame": null,
        "unfocusedFrame": null,
        "useMica": false
      }
    }
  ]
}
