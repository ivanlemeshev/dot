#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
COLOR_DIR="$PROJECT_ROOT/color"
TARGETS_FILE="$COLOR_DIR/targets.tsv"

YAML="${1:-$COLOR_DIR/schemes/gruvbox-dark-material.yaml}"
if [[ ! -f "$YAML" ]]; then
  echo "Error: Color scheme YAML file not found at $YAML"
  echo "Usage: $0 [path/to/theme.yaml]"
  exit 1
fi

echo "Applying theme: $YAML"

while IFS='|' read -r generator target; do
  [[ -z "$generator" ]] && continue
  python3 "$COLOR_DIR/$generator" "$YAML" "$PROJECT_ROOT/$target"
done <"$TARGETS_FILE"
