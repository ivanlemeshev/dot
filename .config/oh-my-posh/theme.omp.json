{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#6c7086",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": "{{ .CurrentDate | date .Format }}  ",
          "type": "time"
        },
        {
          "foreground": "#cdd6f4",
          "style": "plain",
          "template": "{{ if ne .Env.POSH_SESSION_DEFAULT_USER .UserName }}<#89b4fa>{{ .UserName }}</><#cdd6f4>@</></>{{ end }}<#74c7ec>{{ .HostName }}</>  ",
          "type": "session"
        },
        {
          "foreground": "#f38ba8",
          "style": "plain",
          "template": "󱐋  ",
          "type": "root"
        },
        {
          "foreground": "#cdd6f4",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": "{{ .Path }}  ",
          "type": "path"
        },
        {
          "foreground": "#a6e3a1",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#fab387{{ end }}",
            "{{ if gt .Ahead 0 }}#74c7ec{{ end }}",
            "{{ if gt .Behind 0 }}#f38ba8{{ end }}"
          ],
          "options": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": false
          },
          "style": "plain",
          "template": "git({{ .HEAD }}){{ if .Working.Changed }}<#f38ba8> {{ .Working.String }}</>{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }}{{ end }}{{ if .Staging.Changed }}<#a6e3a1> {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} [{{ .StashCount }}] {{ end }}  ",
          "type": "git"
        },
        {
          "foreground": "#f9e2af",
          "options": {
            "style": "roundrock",
            "threshold": 500
          },
          "style": "plain",
          "template": "{{ .FormattedMs }}  ",
          "type": "executiontime"
        },
        {
          "foreground": "#a6e3a1",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#f38ba8{{ end }}"
          ],
          "options": {
            "always_enabled": false
          },
          "style": "plain",
          "template": "{{ if gt .Code 0 }}exit({{ .Code }})  {{ end }}",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#cdd6f4",
          "style": "plain",
          "template": "<#fab387>$</>",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}root :: {{end}}{{.Shell}} :: {{.Folder}}",
  "final_space": true,
  "version": 4
}
