{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#d4be98",
          "style": "plain",
          "template": "{{ if ne .Env.POSH_SESSION_DEFAULT_USER .UserName }}<#d8a657>{{ .UserName }}</><#d4be98>@</></>{{ end }}<#7daea3>{{ .HostName }}</><#7c6f64> | </>",
          "type": "session"
        },
        {
          "foreground": "#ea6962",
          "style": "plain",
          "template": "󱐋<#7c6f64> | </>",
          "type": "root"
        },
        {
          "foreground": "#d4be98",
          "options": {
            "style": "folder"
          },
          "style": "plain",
          "template": "{{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#a9b665",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#d8a657{{ end }}",
            "{{ if gt .Ahead 0 }}#7daea3{{ end }}",
            "{{ if gt .Behind 0 }}#ea6962{{ end }}"
          ],
          "options": {
            "branch_icon": " ",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "style": "plain",
          "template": "<#7c6f64>| </>{{ .UpstreamIcon }}{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }}<#ea6962> {{ .Working.String }}</>{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }}{{ end }}{{ if .Staging.Changed }}<#a9b665> {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} [{{ .StashCount }}]{{ end }} ",
          "type": "git"
        },
        {
          "foreground": "#a9b665",
          "options": {
            "time_format": "15:04:05"
          },
          "style": "plain",
          "template": "<#7c6f64>| </>{{ .CurrentDate | date .Format }} ",
          "type": "time"
        },
        {
          "foreground": "#d8a657",
          "options": {
            "style": "roundrock",
            "threshold": 500
          },
          "style": "plain",
          "template": "<#7c6f64>| </>{{ .FormattedMs }} </>",
          "type": "executiontime"
        },
        {
          "foreground": "#a9b665",
          "foreground_templates": ["{{ if gt .Code 0 }}#ea6962{{ end }}"],
          "options": {
            "always_enabled": false
          },
          "style": "plain",
          "template": "<#7c6f64>| </>{{ if gt .Code 0 }} {{ .Code }}{{ end }} ",
          "type": "status"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#d4be98",
          "style": "plain",
          "template": "<#7daea3>$</>",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{if .Root}}root :: {{end}}{{.Shell}} :: {{.Folder}}",
  "final_space": true,
  "version": 4
}
